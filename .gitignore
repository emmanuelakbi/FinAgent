# ==========================================================================
# FinAgent — .gitignore
# ==========================================================================
# Keeps secrets, caches, and local-only state out of the public repo.

# --- Kiro spec-driven dev state (internal planning, not for public repo) --
.kiro/

# --- Internal runbooks / deployment plans (not for public repo) ----------
# These contain internal timing, TODOs, and local paths — useful while
# working on the project but not suitable for the public hackathon repo.
DEPLOYMENT_PLAN.md
DEPLOY_AMD.md
DEPLOY_HF.md
WHAT_TO_DO_NOW.md

# --- Submission drafts (pitch deck + video script, local only) -----------
finagent-deck-web/
finagent-video-script.md

# --- Python ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
.env
.env.*
!.env.example

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/

# Hypothesis (property-based test state — large, regenerable)
.hypothesis/

# Mypy / Ruff / Pyright caches
.mypy_cache/
.ruff_cache/
.pyright/
.pytype/

# --- Jupyter / IPython ---------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- OS / Editor ---------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# VS Code / Cursor / JetBrains
.vscode/
!.vscode/extensions.json
.idea/
*.iml
*.swp
*.swo

# --- Secrets -------------------------------------------------------------
# Never commit API keys, tokens, or endpoint URLs pointing at live services.
*.pem
*.key
.hf_token
.secrets
secrets.yaml
secrets.yml

# --- Logs & runtime ------------------------------------------------------
*.log
logs/
*.pid
tmp/
temp/

# --- Model / data artifacts (heavy; fetched at runtime) -----------------
models/
*.bin
*.safetensors
*.gguf
*.ckpt
data/raw/
data/cache/
*.csv.gz

# --- vLLM / ROCm runtime state ------------------------------------------
vllm_cache/
.rocm_cache/

# --- Hugging Face Space local checkout ----------------------------------
# If you clone the HF Space for local edits, put the checkout here.
hf-space-checkout/

# --- Agent / Kiro state --------------------------------------------------
# .kiro/ is ignored entirely (see top of file) — spec-driven-development
# artifacts stay local and are not published to the public repo.

# --- Node (in case any frontend tooling sneaks in) ----------------------
node_modules/
.npm
.pnpm-store/
